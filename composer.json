{
  "name": "geodit/vm-osjs",
  "description": "Standalone VM OS.js builder package for Laravel",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "illuminate/support": "^12.0",
    "illuminate/routing": "^12.0",
    "illuminate/view": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "Geodit\\VmOsjs\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "Geodit\\VmOsjs\\VmOsjsServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
